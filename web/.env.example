VITE_API_BASE_URL=/api/v1
VITE_USE_MOCK=false

# ─────────────────────────────────────────────────
# 素材库上游 (v0.9.4 §2.8 多上游切换)
# ─────────────────────────────────────────────────
# 选择当前生效的素材库 provider:
#   - seegen        SeeGen AI,REST + Bearer,key 内置在前端 bundle (开发期方便)
#   - volcano_ark   火山方舟 ARK OpenAPI,HMAC-SHA256 签名,走后端 /v1/ark/* 代签
# 不设默认 seegen,保持向后兼容。
# 切换 provider 后,已上传的角色 ark_group_id 与新 provider 不兼容,
# 首次再次上传时 ensureRealAssetGroup() 会自动以当前 provider 重新建组。
VITE_ASSET_LIB_PROVIDER=seegen

# 角色库素材上传 — SeeGen + TOS(VITE_ASSET_LIB_PROVIDER=seegen 时启用)
# ─────────────────────────────────────────────────
# SeeGen REST 客户端默认走 /seegen-proxy/v1,Authorization Bearer 用此处 key。
# 不填则用 api/seegen.ts 内置的 BUILTIN_SEEGEN_API_KEY。
VITE_SEEGEN_API_KEY=sk-ae623dc7123e830ad9229df67dbccf0f14529dea7ef9268ab0e6f04221f1fb33
# VITE_SEEGEN_BASE_URL=/seegen-proxy/v1

# 火山方舟 ARK provider (VITE_ASSET_LIB_PROVIDER=volcano_ark 时启用)
# ─────────────────────────────────────────────────
# AK/SK 不在前端 bundle,统一走后端 /v1/ark/* 中转(server/.env 配 VOLCANO_*)。

# TOS 直传(浏览器 AWS SigV4)— 默认使用 face-bucket-metamind / cn-hongkong。
# 切桶时把下面四个填上。桶必须配置 CORS 允许 PUT / GET / ETag,详见 tosUpload.ts 顶部注释。
# VITE_TOS_AK=
# VITE_TOS_SK=
# VITE_TOS_BUCKET=
# VITE_TOS_ENDPOINT=
# VITE_TOS_REGION=
