VITE_API_BASE_URL=/api/v1

# 数据层(项目 / 角色 / 任务 / 账户余额)继续走 localStorage mock
# —— 后端只实现了 auth,业务数据库还没做,先保持 mock 让 demo 不卡
VITE_USE_MOCK=true

# 鉴权(登录 / 注册 / OAuth / 改昵称密码)走真实后端 /api/v1/auth/*
# —— 这一项是 production 关键,让真账号 + GitHub/Google OAuth 真正生效
VITE_USE_REAL_AUTH=true

# v0.9.4 §2.8 多上游素材库 provider 选择
# seegen | volcano_ark — volcano_ark 时走后端 /v1/ark/* 代签
VITE_ASSET_LIB_PROVIDER=volcano_ark
